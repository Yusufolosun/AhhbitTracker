# ─────────────────────────────────────────────
# AhhbitTracker — Root Environment Variables
# ─────────────────────────────────────────────
# Used by contract deployment and automation scripts only.
# Copy to .env.local and fill in real values. NEVER commit .env.local.
# For staged setup, use .env.development.example, .env.staging.example,
# or .env.production.example as your starting point.
#
# Frontend environment variables live in frontend/.env.example
# ─────────────────────────────────────────────

# Stage marker used by script runtime config loader.
APP_STAGE=production

# Stacks network target
STACKS_NETWORK=mainnet
STACKS_API_URL=https://api.mainnet.hiro.so

# Deployed contract details (public, safe to commit)
CONTRACT_ADDRESS=SP1N3809W9CBWWX04KN3TCQHP8A9GN520BD4JMP8Z
CONTRACT_NAME=habit-tracker-v2
DEPLOYER_ADDRESS=SP1N3809W9CBWWX04KN3TCQHP8A9GN520BD4JMP8Z

# ── SENSITIVE — never commit real values ───────
# DEPLOYER_PRIVATE_KEY=<64-char hex key — goes in settings/Mainnet.toml, NOT here>
