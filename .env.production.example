# AhhbitTracker production environment (root scripts)
# Copy to .env.production.local for production automation.
# Never commit .env.production.local.

APP_STAGE=production
STACKS_NETWORK=mainnet
# Must match STACKS_NETWORK. Use https URLs; http is allowed only for localhost.
STACKS_API_URL=https://api.mainnet.hiro.so

# Mainnet contract values.
CONTRACT_ADDRESS=SP1N3809W9CBWWX04KN3TCQHP8A9GN520BD4JMP8Z
CONTRACT_NAME=habit-tracker-v2
DEPLOYER_ADDRESS=SP1N3809W9CBWWX04KN3TCQHP8A9GN520BD4JMP8Z
