# AhhbitTracker frontend development environment
# Copy to .env.development.local for local work.
# Never commit .env.development.local.

VITE_APP_STAGE=development
VITE_STACKS_NETWORK=testnet
# Must match VITE_STACKS_NETWORK. Use https URLs; http is allowed only for localhost.
VITE_STACKS_API_URL=https://api.testnet.hiro.so

# Development contract defaults (testnet)
VITE_CONTRACT_ADDRESS=ST1M46W6CVGAMH3ZJD3TKMY5KCY48HWAZK1GA0CF0
VITE_CONTRACT_NAME=habit-tracker-v2

# Optional canonical URL for local metadata previews
VITE_APP_URL=http://localhost:3000
