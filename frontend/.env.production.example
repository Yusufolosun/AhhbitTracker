# AhhbitTracker frontend production environment
# Copy to .env.production.local for production builds.
# Never commit .env.production.local.

VITE_APP_STAGE=production
VITE_STACKS_NETWORK=mainnet
# Must match VITE_STACKS_NETWORK. Use https URLs; http is allowed only for localhost.
VITE_STACKS_API_URL=https://api.mainnet.hiro.so

# Production contract defaults (mainnet deployment)
VITE_CONTRACT_ADDRESS=SP1N3809W9CBWWX04KN3TCQHP8A9GN520BD4JMP8Z
VITE_CONTRACT_NAME=habit-tracker-v2

# Production canonical URL for metadata and social cards
VITE_APP_URL=https://ahhbit-tracker.vercel.app
