# AhhbitTracker frontend staging environment
# Copy to .env.staging.local for staging builds.
# Never commit .env.staging.local.

VITE_APP_STAGE=staging
VITE_STACKS_NETWORK=testnet
VITE_STACKS_API_URL=https://api.testnet.hiro.so

# Staging contract defaults (dedicated testnet deployment)
VITE_CONTRACT_ADDRESS=ST1M46W6CVGAMH3ZJD3TKMY5KCY48HWAZK1GA0CF0
VITE_CONTRACT_NAME=habit-tracker-v2

# Staging canonical URL for metadata and social cards
VITE_APP_URL=https://staging.ahhbittracker.app
