# ─────────────────────────────────────────────
# AhhbitTracker — Frontend Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env.local for local development.
# .env.local is gitignored — NEVER commit it.
#
# On Vercel: add these in Project Settings → Environment Variables.
# All variables are optional; defaults point to the live mainnet contract.
# ─────────────────────────────────────────────

# Public URL of the deployed site (used for OG image meta tags).
# Set this in Vercel Project Settings → Environment Variables.
# VITE_APP_URL=https://ahhbittracker.vercel.app

# Deployed contract principal (defaults to the live mainnet address).
# Override only if you deploy your own copy of the contract.
# VITE_CONTRACT_ADDRESS=SP1N3809W9CBWWX04KN3TCQHP8A9GN520BD4JMP8Z

# Contract name (defaults to "habit-tracker-v2").
# VITE_CONTRACT_NAME=habit-tracker-v2

# Stacks API URL used by the dev-server proxy (defaults to mainnet).
# Set to testnet or a local devnet URL for non-mainnet development.
# VITE_STACKS_API_URL=https://api.testnet.hiro.so
